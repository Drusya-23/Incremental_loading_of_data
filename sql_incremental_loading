----Creating target table
CREATE TABLE Staff_Target (
    Staff_ID INT,
    Name VARCHAR(50),
    Salary INT,
    ModifiedDate DATETIME
);

----Creating stored procedure
CREATE PROCEDURE UpdateWatermark1
AS
BEGIN
    UPDATE Watermark1
    SET LastLoadDate = GETDATE()
    WHERE TableName = 'company_staff'
END

